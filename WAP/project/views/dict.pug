doctype html
head
  meta(charset='UTF-8')
  meta(http-equiv='X-UA-Compatible' content='IE=edge')
  meta(name='viewport' content='width=device-width, initial-scale=1.0')
  style
    include ../includes/dict.css
  script(src='https://ajax.googleapis.com/ajax/libs/jquery/1.7.2/jquery.min.js' type='text/javascript')
  script(src='../javascripts/dict.js')
  title WAP Dictionary
body  
  div.main
    h1 WAP Online Dictionary
    div.search
      input(type='text' name='term' id='term' placeholder='Write term')
      input(type='submit' value='Lookup' id="submit")
    div.result(id="result") 
  
